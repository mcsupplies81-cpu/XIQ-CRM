          },
          "extract_js": "(output_data)=>extract(\"wiza_reveal_person\", output_data, \"phone\")",
          "run_if_js": "const __dlGetByPath=(obj,path)=>String(path||'').replace(/\\[(\\d+)\\]/g,'.$1').split('.').filter(Boolean).reduce((cur,key)=>{if(cur==null)return undefined;if(cur&&typeof cur==='object'){if(key in cur)return cur[key];const data=cur.data;if(data&&typeof data==='object'&&key in data)return data[key];}return undefined;},obj);const __dlMeaningful=(value)=>{if(value&&typeof value==='object'&&!Array.isArray(value)&&'data'in value)return __dlMeaningful(value.data);return value!==null&&value!==undefined&&!(typeof value==='string'&&value.trim()==='');};if (![\"cell_phone__linkedin_url\"].every((path)=>__dlMeaningful(__dlGetByPath(row,path)))) return false;return true;"
        },
        {
          "alias": "cell_phone__native_phone",
          "tool": "deepline_native_enrich_phone",
          "operation": "enrich_phone",
          "payload": {
            "linkedin": "{{cell_phone__linkedin_url}}",
            "first_name": "{{first_name}}",
            "last_name": "{{last_name}}",
            "domain": "{{domain}}"
          },
          "extract_js": "(output_data)=>extract(\"deepline_native_enrich_phone\", output_data, \"phone\")",
          "run_if_js": "const __dlGetByPath=(obj,path)=>String(path||'').replace(/\\[(\\d+)\\]/g,'.$1').split('.').filter(Boolean).reduce((cur,key)=>{if(cur==null)return undefined;if(cur&&typeof cur==='object'){if(key in cur)return cur[key];const data=cur.data;if(data&&typeof data==='object'&&key in data)return data[key];}return undefined;},obj);const __dlMeaningful=(value)=>{if(value&&typeof value==='object'&&!Array.isArray(value)&&'data'in value)return __dlMeaningful(value.data);return value!==null&&value!==undefined&&!(typeof value==='string'&&value.trim()==='');};if (![\"cell_phone__linkedin_url\",\"first_name\",\"last_name\",\"domain\"].every((path)=>__dlMeaningful(__dlGetByPath(row,path)))) return false;return true;"
        }
